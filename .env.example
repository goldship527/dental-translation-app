# Silence detection thresholds
NEXT_PUBLIC_SILENCE_MIN_DURATION=0.6
NEXT_PUBLIC_SILENCE_PEAK=0.025
NEXT_PUBLIC_SILENCE_RMS=0.006
NEXT_PUBLIC_SILENCE_SPEECH_RATIO=0.01
